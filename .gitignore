# ============================================================
#  KafeAdisyon — .NET MAUI (Android / iOS / MacCatalyst / Windows)
#  Git tarafından takip edilmeyecek dosyalar
# ============================================================


# ------------------------------------------------------------
# DERLEME ÇIKTILARI — bin / obj
# ------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/


# ------------------------------------------------------------
# VISUAL STUDIO IDE DOSYALARI
# ------------------------------------------------------------

# VS solution user options (kişisel pencere/breakpoint ayarları)
*.suo
*.user
*.userosscache
*.sln.docstates

# VS gizli klasörü (workspace ayarları, arama indeksleri vb.)
.vs/

# Roslyn test runners
_ReSharper*/
*.ReSharper

# Rider IDE
.idea/
*.sln.iml


# ------------------------------------------------------------
# NUGET PAKETLERİ
# ------------------------------------------------------------
packages/
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/         # Build integration dosyaları teslim edilebilir
nuget.config                   # Özel feed/credential içeriyorsa

# NuGet lock file — opsiyonel, takıma göre karar verin
# packages.lock.json


# ------------------------------------------------------------
# HASSAS YAPILANDIRMA DOSYALARI ⚠️
# (Supabase URL ve anahtar içeriyor)
# ------------------------------------------------------------
appsettings.json
appsettings.*.json

# Şablonları repoda bırakın (anahtar YOK, sadece yapı var):
# appsettings.example.json
# appsettings.test.example.json


