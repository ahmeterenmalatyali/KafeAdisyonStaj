<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafeAdisyon.Views.Order.SplitBillPage"
             BackgroundColor="#00000066">

    <Grid>
        <Button BackgroundColor="#000000" Opacity="0.5"
                BorderWidth="0" CornerRadius="0"
                Clicked="OnBackdropClicked"/>

        <Border BackgroundColor="#FAF7F2"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                Padding="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="420">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Başlık -->
                <Border Grid.Row="0" BackgroundColor="#3D2314"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20,20,0,0"
                        Padding="20,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="✂️ Hesap Böl"
                                   FontSize="17" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="Seçtiğiniz ürünlerin hesabını ayırın"
                                   FontSize="11" TextColor="#C4956A"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#5C3317"
                                StrokeThickness="0" StrokeShape="RoundRectangle 20"
                                Padding="14,8" VerticalOptions="Center">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="Seçilen Toplam" FontSize="10"
                                       TextColor="#C4956A" HorizontalOptions="Center"/>
                                <Label x:Name="SplitTotalLabel" Text="₺0,00"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="#F5C896" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- Ürün listesi -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="400" Padding="16,12">
                    <VerticalStackLayout x:Name="ItemsLayout" Spacing="8"/>
                </ScrollView>

                <!-- Butonlar -->
                <Grid Grid.Row="2" ColumnDefinitions="*,*"
                      Padding="16,12" ColumnSpacing="10" BackgroundColor="White">
                    <Button Grid.Column="0"
                            Text="Kapat"
                            Clicked="OnBackdropClicked"
                            BackgroundColor="#F0E6DA"
                            TextColor="#3D2314"
                            CornerRadius="12"
                            HeightRequest="48"
                            FontSize="14"/>
                    <Button Grid.Column="1"
                            x:Name="PayBtn"
                            Text="✅ Öde ve Kaldır"
                            Clicked="OnPayClicked"
                            BackgroundColor="#3D2314"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"
                            FontSize="14"
                            FontAttributes="Bold"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</ContentPage>