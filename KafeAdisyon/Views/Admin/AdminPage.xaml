<?xml version="1.0" encoding="utf-8" ?>
<views:TablePageBase xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:KafeAdisyon.Views"
             x:Class="KafeAdisyon.Views.Admin.AdminPage"
             BackgroundColor="#FAF7F2">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#3D2314"
                StrokeThickness="0" Padding="20,14">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Label Grid.Column="0" Text="☕" FontSize="24" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" Spacing="1">
                    <Label Text="Admin Paneli" FontSize="18" FontAttributes="Bold" TextColor="#FFFFFF"/>
                    <Label Text="KOZA KAFE" FontSize="11" TextColor="#C4956A" CharacterSpacing="2"/>
                </VerticalStackLayout>
                <Border Grid.Column="2" BackgroundColor="#5C3317"
                        StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="12,6"
                        Margin="0,0,8,0">
                    <Label Text="👑 Admin" TextColor="#F5C896" FontSize="12"/>
                </Border>
                <Button Grid.Column="3"
                        Text="Çıkış"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#5C3317"
                        TextColor="#F5C896"
                        FontSize="12"
                        CornerRadius="20"
                        Padding="12,6"
                        HeightRequest="36"
                        BorderWidth="0"/>
            </Grid>
        </Border>

        <!-- Tab Bar — 3 sekme -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*"
              BackgroundColor="#FAF7F2" Padding="16,12,16,8" ColumnSpacing="6">
            <Button Grid.Column="0" x:Name="TabTables"
                    Text="🪑  Masalar" Clicked="OnTabTables"
                    BackgroundColor="#3D2314" TextColor="White"
                    FontAttributes="Bold" FontSize="14"
                    CornerRadius="12" HeightRequest="44"/>
            <Button Grid.Column="1" x:Name="TabMenu"
                    Text="🍽️  Menü" Clicked="OnTabMenu"
                    BackgroundColor="White" TextColor="#A0856A"
                    FontSize="14" CornerRadius="12" HeightRequest="44"/>
            <Button Grid.Column="2" x:Name="TabReport"
                    Text="📊  Rapor" Clicked="OnTabReport"
                    BackgroundColor="White" TextColor="#A0856A"
                    FontSize="14" CornerRadius="12" HeightRequest="44"/>
        </Grid>

        <ScrollView Grid.Row="2" Padding="16,4,16,20">
            <VerticalStackLayout Spacing="16">

                <!-- MASALAR -->
                <VerticalStackLayout x:Name="TablesSection" Spacing="12">
                    <HorizontalStackLayout Spacing="16" Padding="4,0">
                        <HorizontalStackLayout Spacing="6">
                            <BoxView Color="#4CAF50" WidthRequest="10" HeightRequest="10"
                                     CornerRadius="5" VerticalOptions="Center"/>
                            <Label Text="Boş" TextColor="#A0856A" FontSize="12"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="6">
                            <BoxView Color="#E53935" WidthRequest="10" HeightRequest="10"
                                     CornerRadius="5" VerticalOptions="Center"/>
                            <Label Text="Dolu" TextColor="#A0856A" FontSize="12"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Button x:Name="BtnA1" Grid.Row="0" Grid.Column="0" Text="A-1"
                                Clicked="OnTableClicked" CommandParameter="A-1"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnA2" Grid.Row="1" Grid.Column="0" Text="A-2"
                                Clicked="OnTableClicked" CommandParameter="A-2"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0"
                                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                            <Label Text="🚪" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Giriş" TextColor="#C8702A" FontSize="11"
                                   CharacterSpacing="1" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Button x:Name="BtnA3" Grid.Row="3" Grid.Column="0" Text="A-3"
                                Clicked="OnTableClicked" CommandParameter="A-3"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnA4" Grid.Row="4" Grid.Column="0" Text="A-4"
                                Clicked="OnTableClicked" CommandParameter="A-4"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnB1" Grid.Row="0" Grid.Column="1" Text="B-1"
                                Clicked="OnTableClicked" CommandParameter="B-1"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnB2" Grid.Row="1" Grid.Column="1" Text="B-2"
                                Clicked="OnTableClicked" CommandParameter="B-2"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnB3" Grid.Row="2" Grid.Column="1" Text="B-3"
                                Clicked="OnTableClicked" CommandParameter="B-3"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnB4" Grid.Row="3" Grid.Column="1" Text="B-4"
                                Clicked="OnTableClicked" CommandParameter="B-4"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnB5" Grid.Row="4" Grid.Column="1" Text="B-5"
                                Clicked="OnTableClicked" CommandParameter="B-5"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnC1" Grid.Row="0" Grid.Column="2" Text="C-1"
                                Clicked="OnTableClicked" CommandParameter="C-1"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnC2" Grid.Row="1" Grid.Column="2" Text="C-2"
                                Clicked="OnTableClicked" CommandParameter="C-2"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnC3" Grid.Row="2" Grid.Column="2" Text="C-3"
                                Clicked="OnTableClicked" CommandParameter="C-3"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnC4" Grid.Row="3" Grid.Column="2" Text="C-4"
                                Clicked="OnTableClicked" CommandParameter="C-4"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                        <Button x:Name="BtnC5" Grid.Row="4" Grid.Column="2" Text="C-5"
                                Clicked="OnTableClicked" CommandParameter="C-5"
                                BackgroundColor="#E8F5E9" TextColor="#2C1810"
                                BorderColor="#C8E6C9" BorderWidth="1.5"
                                CornerRadius="14" HeightRequest="60" FontSize="16" FontAttributes="Bold"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- MENÜ -->
                <VerticalStackLayout x:Name="MenuSection" IsVisible="False" Spacing="12">

                    <Border BackgroundColor="White" StrokeThickness="1"
                            Stroke="#F0E6DA" StrokeShape="RoundRectangle 14"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Yeni Ürün Ekle" FontSize="15"
                                   FontAttributes="Bold" TextColor="#3D2314"/>
                            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Placeholder="Ürün adı"
                                       PlaceholderColor="#C4B09A"
                                       TextColor="#2C1810"
                                       BackgroundColor="#FAF7F2"
                                       Text="{Binding NewItemName}"
                                       FontSize="14"/>
                                <Picker Grid.Column="1"
                                        x:Name="NewItemCategoryPicker"
                                        Title="Kategori seç"
                                        TitleColor="#C4B09A"
                                        TextColor="#2C1810"
                                        BackgroundColor="#FAF7F2"
                                        FontSize="14"
                                        SelectedIndexChanged="OnNewItemCategoryPickerChanged"/>
                                <Entry Grid.Column="2"
                                       Placeholder="₺ Fiyat"
                                       PlaceholderColor="#C4B09A"
                                       TextColor="#2C1810"
                                       BackgroundColor="#FAF7F2"
                                       Text="{Binding NewItemPrice}"
                                       Keyboard="Numeric"
                                       WidthRequest="100"
                                       FontSize="14"/>
                            </Grid>
                            <Button Text="+ Ürün Ekle"
                                    Clicked="OnAddMenuItemClicked"
                                    BackgroundColor="#3D2314"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    FontSize="14"
                                    FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <ScrollView Orientation="Horizontal" Padding="0,4">
                        <HorizontalStackLayout x:Name="MenuCategoryButtons" Spacing="8"/>
                    </ScrollView>

                    <VerticalStackLayout x:Name="MenuListLayout" Spacing="0"/>

                </VerticalStackLayout>

                <!-- RAPOR -->
                <VerticalStackLayout x:Name="ReportSection" IsVisible="False" Spacing="12">

                    <!-- Tarih Aralığı -->
                    <Border BackgroundColor="White" StrokeThickness="1"
                            Stroke="#F0E6DA" StrokeShape="RoundRectangle 14"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tarih Aralığı" FontSize="15"
                                   FontAttributes="Bold" TextColor="#3D2314"/>
                            <!-- AGENTS.md: Picker Windows'ta bozuluyor → Toggle Button -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button x:Name="BtnToday" Grid.Column="0"
                                        Text="Bugün"
                                        BackgroundColor="#3D2314" TextColor="White"
                                        CornerRadius="10" HeightRequest="42" FontSize="14"
                                        Clicked="OnRangeSelected"/>
                                <Button x:Name="BtnThisWeek" Grid.Column="1"
                                        Text="Bu Hafta"
                                        BackgroundColor="White" TextColor="#A0856A"
                                        BorderColor="#E8D5C4" BorderWidth="1"
                                        CornerRadius="10" HeightRequest="42" FontSize="14"
                                        Clicked="OnRangeSelected"/>
                            </Grid>
                            <Label x:Name="LblDateRange"
                                   Text="Bugün seçili"
                                   FontSize="12" TextColor="#A0856A"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Rapor Başlığı -->
                    <Border BackgroundColor="White" StrokeThickness="1"
                            Stroke="#F0E6DA" StrokeShape="RoundRectangle 14"
                            Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Rapor Başlığı" FontSize="15"
                                   FontAttributes="Bold" TextColor="#3D2314"/>
                            <Entry x:Name="EntryReportTitle"
                                   Placeholder="ör. 27 Mart 2026 Satış Raporu"
                                   BackgroundColor="#FAF7F2"
                                   TextColor="#2C1810"
                                   PlaceholderColor="#C4B09A"
                                   FontSize="14"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Oluştur Butonu -->
                    <Button x:Name="BtnGenerate"
                            Text="📄  PDF Oluştur ve Yükle"
                            BackgroundColor="#C8702A" TextColor="White"
                            FontSize="15" FontAttributes="Bold"
                            CornerRadius="12" HeightRequest="52"
                            Clicked="OnGenerateReportClicked"/>

                    <!-- Yükleniyor -->
                    <ActivityIndicator x:Name="ReportSpinner"
                                       IsRunning="False" IsVisible="False"
                                       Color="#C8702A" HeightRequest="40"/>

                    <!-- Başarı Kartı -->
                    <Border x:Name="ReportResultCard" IsVisible="False"
                            BackgroundColor="White" StrokeThickness="1"
                            Stroke="#C8E6C9" StrokeShape="RoundRectangle 14"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="✅ Rapor Hazır"
                                   FontAttributes="Bold" FontSize="14" TextColor="#3D2314"/>
                            <Label x:Name="LblReportUrl"
                                   FontSize="11" TextColor="#A0856A"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Text="🔗 Aç"
                                        BackgroundColor="#3D2314" TextColor="White"
                                        CornerRadius="8" HeightRequest="40"
                                        Clicked="OnOpenReportLinkClicked"/>
                                <Button Grid.Column="1"
                                        Text="📋 Kopyala"
                                        BackgroundColor="White" TextColor="#5C3317"
                                        BorderColor="#E8D5C4" BorderWidth="1"
                                        CornerRadius="8" HeightRequest="40"
                                        Clicked="OnCopyReportLinkClicked"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Hata Kartı -->
                    <Border x:Name="ReportErrorCard" IsVisible="False"
                            BackgroundColor="#FFEBEE" StrokeThickness="1"
                            Stroke="#FFCDD2" StrokeShape="RoundRectangle 14"
                            Padding="16">
                        <Label x:Name="LblReportError"
                               FontSize="12" TextColor="#B71C1C"/>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</views:TablePageBase>
