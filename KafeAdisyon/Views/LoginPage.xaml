<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafeAdisyon.Views.LoginPage"
             BackgroundColor="#FAF7F2"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto,*">

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="36,0"
                                 HorizontalOptions="Center"
                                 WidthRequest="340">

                <!-- Logo -->
                <Border BackgroundColor="#3D2314"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32"
                        WidthRequest="90" HeightRequest="90"
                        HorizontalOptions="Center"
                        Margin="0,32,0,20">
                    <Label Text="☕" FontSize="44"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="KOZA KAFE"
                       FontSize="30" FontAttributes="Bold"
                       TextColor="#3D2314"
                       HorizontalOptions="Center"
                       CharacterSpacing="5"
                       Margin="0,0,0,6"/>

                <Label Text="Adisyon Yönetim Sistemi"
                       FontSize="13" TextColor="#A0856A"
                       HorizontalOptions="Center"
                       Margin="0,0,0,36"/>

                <!-- Giriş Formu -->
                <Border BackgroundColor="White"
                        StrokeThickness="1" Stroke="#E8D5C4"
                        StrokeShape="RoundRectangle 16"
                        Padding="20" Margin="0,0,0,14">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="E-posta" FontSize="12"
                               TextColor="#A0856A" FontAttributes="Bold"/>
                        <Border BackgroundColor="#FAF7F2"
                                StrokeThickness="1" Stroke="#E8D5C4"
                                StrokeShape="RoundRectangle 10">
                            <Entry x:Name="EntryEmail"
                                   Placeholder="ornek@kafe.com"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"
                                   TextColor="#2C1810"
                                   PlaceholderColor="#C4B09A"
                                   FontSize="14"
                                   Margin="12,8"/>
                        </Border>

                        <Label Text="Şifre" FontSize="12"
                               TextColor="#A0856A" FontAttributes="Bold"/>
                        <Border BackgroundColor="#FAF7F2"
                                StrokeThickness="1" Stroke="#E8D5C4"
                                StrokeShape="RoundRectangle 10">
                            <Entry x:Name="EntryPassword"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   TextColor="#2C1810"
                                   PlaceholderColor="#C4B09A"
                                   FontSize="14"
                                   Margin="12,8"/>
                        </Border>

                        <Label Text="Cihaz Adı" FontSize="12"
                               TextColor="#A0856A" FontAttributes="Bold"/>
                        <Border BackgroundColor="#FAF7F2"
                                StrokeThickness="1" Stroke="#E8D5C4"
                                StrokeShape="RoundRectangle 10">
                            <Entry x:Name="EntryDevice"
                                   Placeholder="ör. Kasa-1, Garson-Tablet"
                                   BackgroundColor="Transparent"
                                   TextColor="#2C1810"
                                   PlaceholderColor="#C4B09A"
                                   FontSize="14"
                                   Margin="12,8"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Hata mesajı -->
                <Label x:Name="LblError"
                       IsVisible="False"
                       TextColor="#B71C1C"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <!-- Giriş Butonu -->
                <Button x:Name="BtnLogin"
                        Text="Giriş Yap"
                        BackgroundColor="#3D2314"
                        TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="54"
                        Clicked="OnLoginClicked"
                        Margin="0,0,0,12"/>

                <!-- Yükleniyor -->
                <ActivityIndicator x:Name="Spinner"
                                   IsRunning="False" IsVisible="False"
                                   Color="#C8702A" HeightRequest="36"/>

                <Label Grid.Row="2" Text="v2.0 — Koza Kafe"
                       TextColor="#C4B09A" FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,20,0,32"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
